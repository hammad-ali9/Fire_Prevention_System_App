rules_version = '2';

// Telemetry is written ONLY by the Cloud Functions (admin SDK bypasses these
// rules). Signed-in app users may READ device telemetry; nobody writes from
// the client. Commands go through the dmSetOutput callable, never direct writes.
service cloud.firestore {
  match /databases/{database}/documents {
    match /devices/{serial} {
      allow read: if request.auth != null;
      allow write: if false;

      match /history/{recordId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }
  }
}
